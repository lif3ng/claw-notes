---
// LangToggle.astro - client-side only, reads/writes localStorage
---

<button class="lang-toggle" id="lang-toggle" aria-label="Toggle language">
  <!-- text set by script -->
  EN
</button>

<script>
  const LANG_KEY = 'claw-notes-lang';

  function getLang(): 'zh' | 'en' {
    const stored = localStorage.getItem(LANG_KEY);
    return stored === 'en' ? 'en' : 'zh';
  }

  function applyLang(lang: 'zh' | 'en') {
    // Update button label
    const btn = document.getElementById('lang-toggle');
    if (btn) btn.textContent = lang === 'zh' ? 'EN' : '中';

    // Show/hide bilingual elements
    document.querySelectorAll('[data-lang-zh]').forEach((el) => {
      (el as HTMLElement).style.display = lang === 'zh' ? '' : 'none';
    });
    document.querySelectorAll('[data-lang-en]').forEach((el) => {
      (el as HTMLElement).style.display = lang === 'en' ? '' : 'none';
    });
  }

  // Init
  const lang = getLang();
  applyLang(lang);

  // Toggle on click
  document.getElementById('lang-toggle')?.addEventListener('click', () => {
    const current = getLang();
    const next = current === 'zh' ? 'en' : 'zh';
    localStorage.setItem(LANG_KEY, next);
    applyLang(next);
  });
</script>
