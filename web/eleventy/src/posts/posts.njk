---
pagination:
  data: posts
  size: 1
  alias: post
permalink: "posts/{{ post.slug }}/index.html"
layout: base.njk
---
<article class="post-single">
  <header class="post-header">
    <h1 class="post-title">
      <span class="lang-zh">{{ post.title_zh }}</span>
      <span class="lang-en">{{ post.title_en }}</span>
    </h1>
    <div class="post-meta">
      <time datetime="{{ post.date }}">{{ post.date }}</time>
      {% if post.tags and post.tags.length > 0 %}
      <span class="post-tags">
        {% for tag in post.tags %}
        <span class="tag">{{ tag }}</span>
        {% endfor %}
      </span>
      {% endif %}
    </div>
  </header>
  <div class="post-content">
    <div class="lang-zh">{{ post.content_zh | safe }}</div>
    <div class="lang-en">{{ post.content_en | safe }}</div>
  </div>
  <footer class="post-footer">
    <a href="/web/eleventy/">
      <span class="lang-zh">&larr; 返回列表</span>
      <span class="lang-en">&larr; Back</span>
    </a>
  </footer>
</article>
